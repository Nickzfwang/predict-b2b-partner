# predict-markets B2B API 憑證（從 predict-markets Partner 後台取得）
PM_API_KEY=pk_test_your_key
PM_API_SECRET=sk_test_your_secret
PM_BASE_URL=http://localhost:8000

# Webhook 驗簽 secret（建立 webhook 後由 predict-markets 回傳）
PM_WEBHOOK_SECRET=whsec_your_secret

# embed 頁面的 base URL（瀏覽器端可見）
# 開發環境：predict-markets 前端（Vite） → http://localhost:5173/embed
# 生產環境：正式域名 → https://your-domain.com/embed
NEXT_PUBLIC_PM_EMBED_BASE_URL=http://localhost:5173/embed

# Demo 用戶清單（逗號分隔，用於 ?user= 切換）
NEXT_PUBLIC_DEMO_USERS=alice,bob,carol
